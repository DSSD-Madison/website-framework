---
import { TypeMember } from "../../contentful-types";
import Person from "./Person.astro";

interface Props {
  title?: string;
  people: TypeMember[];
  filter: (person: TypeMember) => boolean;
  darker?: boolean;
  hideRoles?: boolean;
  small?: boolean;
}

const { title, people, filter, darker, hideRoles, small }: Props = Astro.props;

// Get person's name, rearanged for sorting
const getName = (person: TypeMember) => {
  return person.fields.fullName.split(" ").reverse().join(" ");
};

const getImg = (person: TypeMember) => {
  try {
    if (person.fields.photo) return person.fields.photo.fields.file.url;
  } catch (e) {
    console.error("Error getting image for person: " + person.fields.fullName, e);
  }
  return null;
};

const sortPeople = (a: TypeMember, b: TypeMember) => {
  if (getImg(a) && getImg(b)) return getName(a).localeCompare(getName(b));
  return getImg(a) ? -1 : 1;
};

const sortedPeople = people.sort(sortPeople);
---

<div class={"my-4 flex flex-col items-center " + (darker && "bg-gray-300")}>
  <h1 class="text-2xl text-center mt-4 text-gray-700">{title}</h1>
  <div class="mb-4 mx-4 flex flex-wrap justify-center">
    {
      sortedPeople.map((person) => {
        if (filter(person)) {
          return (
            <Person
              data={person.fields}
              id={person.fields.fullName}
              hideRole={hideRoles}
              {small}
            />
          );
        }
      })
    }
  </div>
</div>
